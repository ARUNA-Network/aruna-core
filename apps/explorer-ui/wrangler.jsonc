{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "aruna-explorer",
  "main": ".output/server/index.mjs",
  "compatibility_date": "2024-09-23",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".output/public"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
